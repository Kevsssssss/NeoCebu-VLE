## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is a combination of the standard GitHub VisualStudio.gitignore
## and common .NET Core / .NET patterns.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Windows image caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on VFAT chunks
$RECYCLE.BIN/

# VS Code files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# AspNetCore generated files
.cr/

# StyleCop
StyleCopReport.xml

# Files for the "Tools" folder
.tlb
.olb
.pdb
.obj
.exe
.cache
.spec
.temp
.tmp

# Backup & temp files from editor or operating system
*~
*.bak
*.cache
*.ilk
*.log
*.patch
*.tmp

# SQLite databases
*.db
*.db-shm
*.db-wal

# npm / node_modules
node_modules/
npm-debug.log*

# Vite / Frontend build artifacts
dist/
dist-ssr/
*.local

# macOS files
.DS_Store
